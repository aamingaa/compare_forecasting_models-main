\@writefile{lot}{\contentsline {table}{\numberline {18}{\ignorespaces Statistical significance tests — Panel~C: Intraclass Correlation Coefficient (\textsc  {icc}\xspace  ; two-way mixed, absolute agreement) for three representative assets at $\ensuremath  {h=24}\xspace  $. High \textsc  {icc}\xspace  values confirm negligible seed-to-seed variation relative to inter-model differences.}}{31}{table.caption.35}\protected@file@percent }
