\@writefile{lot}{\contentsline {table}{\numberline {19}{\ignorespaces Statistical significance tests — Panel~D: Jonckheere-Terpstra (\textsc  {jt}\xspace  ) test for a monotonic relationship between model complexity (parameter count) and \textsc  {rmse}\xspace  rank. A significant positive result would indicate that more parameters reliably yield better ranks. Three complexity groups: $\leq \!30\mathrm  {K}$, $30\mathrm  {K}$--$200\mathrm  {K}$, $>\!200\mathrm  {K}$ parameters.}}{32}{table.caption.37}\protected@file@percent }
\newlabel{tab:stat_tests_jt}{{19}{32}{Statistical significance tests — Panel~D: Jonckheere-Terpstra (\jt ) test for a monotonic relationship between model complexity (parameter count) and \rmse rank. A significant positive result would indicate that more parameters reliably yield better ranks. Three complexity groups: $\leq \!30\mathrm {K}$, $30\mathrm {K}$--$200\mathrm {K}$, $>\!200\mathrm {K}$ parameters}{table.caption.37}{}}
