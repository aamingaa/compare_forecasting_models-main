\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Best-performing model per asset and horizon, determined by lowest mean \textsc  {rmse}\xspace  across three seeds. ModernTCN\xspace  achieves the lowest \textsc  {rmse}\xspace  on 18 of 24~evaluation points (75\%); N-HiTS\xspace  wins on 3~points (all in cryptocurrency); PatchTST\xspace  wins on 3~points (one crypto, one crypto, one forex). Bold highlights non-ModernTCN\xspace  winners, revealing niche asset-specific advantages.}}{21}{table.caption.12}\protected@file@percent }
\newlabel{tab:per_asset_best_models}{{8}{21}{Best-performing model per asset and horizon, determined by lowest mean \rmse across three seeds. \moderntcn achieves the lowest \rmse on 18 of 24~evaluation points (75\%); \nhits wins on 3~points (all in cryptocurrency); \patchtst wins on 3~points (one crypto, one crypto, one forex). Bold highlights non-\moderntcn winners, revealing niche asset-specific advantages}{table.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Global \textsc  {rmse}\xspace  heatmap across eight modern architectures and 24 evaluation points (12~assets $\times $ 2~horizons). Lighter cells indicate lower error. ModernTCN\xspace  and PatchTST\xspace  consistently achieve the lowest \textsc  {rmse}\xspace  values across all asset--horizon combinations. LSTM\xspace  is excluded for visual clarity; the full nine-model variant is provided in Appendix~\ref {sec:app_dual_plots}, Figure~\ref {fig:app_global_heatmap_all}. Values represent mean \textsc  {rmse}\xspace  across three seeds.}}{22}{figure.caption.13}\protected@file@percent }
\newlabel{fig:global_heatmap}{{3}{22}{Global \rmse heatmap across eight modern architectures and 24 evaluation points (12~assets $\times $ 2~horizons). Lighter cells indicate lower error. \moderntcn and \patchtst consistently achieve the lowest \rmse values across all asset--horizon combinations. \lstm is excluded for visual clarity; the full nine-model variant is provided in Appendix~\ref {sec:app_dual_plots}, Figure~\ref {fig:app_global_heatmap_all}. Values represent mean \rmse across three seeds}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Global mean rank comparison across 24 evaluation points (12~assets $\times $ 2~horizons). Lower values indicate better performance. Three distinct tiers are visible: ModernTCN\xspace  and PatchTST\xspace  (ranks 1--2), a middle group of four models (ranks 3--6), and a bottom group comprising TimesNet\xspace  , Autoformer\xspace  , and LSTM\xspace  (ranks 7--9). Error bars represent rank standard deviation across evaluation points.}}{22}{figure.caption.14}\protected@file@percent }
\newlabel{fig:global_rank_comparison}{{4}{22}{Global mean rank comparison across 24 evaluation points (12~assets $\times $ 2~horizons). Lower values indicate better performance. Three distinct tiers are visible: \moderntcn and \patchtst (ranks 1--2), a middle group of four models (ranks 3--6), and a bottom group comprising \timesnet , \autoformer , and \lstm (ranks 7--9). Error bars represent rank standard deviation across evaluation points}{figure.caption.14}{}}
