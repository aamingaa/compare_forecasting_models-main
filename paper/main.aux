\newlabel{fig:pred_btc_itransformer_h4_step1}{{14a}{37}{\itransformer on BTC/USDT, step~1 ($h = 4$)}{figure.caption.42}{}}
\newlabel{sub@fig:pred_btc_itransformer_h4_step1}{{a}{37}{\itransformer on BTC/USDT, step~1 ($h = 4$)}{figure.caption.42}{}}
\newlabel{fig:pred_btc_itransformer_h4_step4}{{14b}{37}{\itransformer on BTC/USDT, step~4 ($h = 4$)}{figure.caption.42}{}}
\newlabel{sub@fig:pred_btc_itransformer_h4_step4}{{b}{37}{\itransformer on BTC/USDT, step~4 ($h = 4$)}{figure.caption.42}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces iTransformer\xspace  (rank~3) on BTC/USDT at $\ensuremath  {h=4}\xspace  $ (seed~123). (a)~At step~1, tracking fidelity is comparable to ModernTCN\xspace  (Figure~\ref {fig:pred_btc_h4_step1}). (b)~At step~4, slightly more amplitude attenuation is visible relative to ModernTCN\xspace  (Figure~\ref {fig:pred_btc_h4_step4}), consistent with the 1.6\% \textsc  {rmse}\xspace  gap. The inverted attention mechanism produces qualitatively similar but measurably weaker temporal representations for short-horizon cryptocurrency forecasting.}}{37}{figure.caption.42}\protected@file@percent }
\newlabel{fig:pred_itransformer_btc}{{14}{37}{\itransformer (rank~3) on BTC/USDT at $\hfour $ (seed~123). (a)~At step~1, tracking fidelity is comparable to \moderntcn (Figure~\ref {fig:pred_btc_h4_step1}). (b)~At step~4, slightly more amplitude attenuation is visible relative to \moderntcn (Figure~\ref {fig:pred_btc_h4_step4}), consistent with the 1.6\% \rmse gap. The inverted attention mechanism produces qualitatively similar but measurably weaker temporal representations for short-horizon cryptocurrency forecasting}{figure.caption.42}{}}
\newlabel{fig:pred_eurusd_moderntcn_h24_step12}{{15a}{37}{\moderntcn on EUR/USD, step~12 ($h = 24$)}{figure.caption.43}{}}
\newlabel{sub@fig:pred_eurusd_moderntcn_h24_step12}{{a}{37}{\moderntcn on EUR/USD, step~12 ($h = 24$)}{figure.caption.43}{}}
\newlabel{fig:pred_dji_patchtst_h24_step12}{{15b}{37}{\patchtst on Dow Jones, step~12 ($h = 24$)}{figure.caption.43}{}}
\newlabel{sub@fig:pred_dji_patchtst_h24_step12}{{b}{37}{\patchtst on Dow Jones, step~12 ($h = 24$)}{figure.caption.43}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {15}{\ignorespaces Medium-horizon actual-versus-predicted overlays at step~12 of the $h = 24$ forecast vector (seed~123). (a)~ModernTCN\xspace  on EUR/USD: directional content is preserved 12 hours ahead while high-frequency amplitude is dampened. (b)~PatchTST\xspace  on Dow Jones: directional integrity is maintained but the forecast envelope is wider than at $\ensuremath  {h=4}\xspace  $, corroborating the $2$--$2.5\times $ \textsc  {rmse}\xspace  amplification (Table~\ref {tab:horizon_degradation_btc}). Both top architectures exhibit amplitude attenuation as the primary degradation mode.}}{37}{figure.caption.43}\protected@file@percent }
\newlabel{fig:pred_medium_horizon}{{15}{37}{Medium-horizon actual-versus-predicted overlays at step~12 of the $h = 24$ forecast vector (seed~123). (a)~\moderntcn on EUR/USD: directional content is preserved 12 hours ahead while high-frequency amplitude is dampened. (b)~\patchtst on Dow Jones: directional integrity is maintained but the forecast envelope is wider than at $\hfour $, corroborating the $2$--$2.5\times $ \rmse amplification (Table~\ref {tab:horizon_degradation_btc}). Both top architectures exhibit amplitude attenuation as the primary degradation mode}{figure.caption.43}{}}
\@writefile{toc}{\contentsline {paragraph}{Long-horizon degradation ($h = 24$, step 24).}{37}{figure.caption.43}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces Long-horizon overlay: ModernTCN\xspace  on BTC/USDT, $h = 24$, step~24 (seed~123). The model retains directional integrity and captures low-frequency trend components, but high-amplitude intra-day reversals are under-predicted. This pattern---directional fidelity without amplitude precision---is the signature of MSE-optimised direct multi-step forecasting at the maximum horizon. The \textsc  {rmse}\xspace  at $h = 24$ (1{,}617.4) represents a 121.1\% degradation relative to $\ensuremath  {h=4}\xspace  $ (731.6; Table~\ref {tab:horizon_degradation_btc}).}}{38}{figure.caption.44}\protected@file@percent }
\newlabel{fig:pred_long_horizon}{{16}{38}{Long-horizon overlay: \moderntcn on BTC/USDT, $h = 24$, step~24 (seed~123). The model retains directional integrity and captures low-frequency trend components, but high-amplitude intra-day reversals are under-predicted. This pattern---directional fidelity without amplitude precision---is the signature of MSE-optimised direct multi-step forecasting at the maximum horizon. The \rmse at $h = 24$ (1{,}617.4) represents a 121.1\% degradation relative to $\hfour $ (731.6; Table~\ref {tab:horizon_degradation_btc})}{figure.caption.44}{}}
